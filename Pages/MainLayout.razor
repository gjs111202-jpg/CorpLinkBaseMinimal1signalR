@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using CorpLinkBaseMinimal.Data
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject SignInManager<User> SignInManager
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavLink class="brand" href="/" Match="NavLinkMatch.All">CorpLink</NavLink>
        <AuthorizeView>
            <Authorized>
                <div class="user-info">
                    Добро пожаловать, @context.User.Identity?.Name!
                    <button class="btn-logout" @onclick="Logout">Выйти</button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="auth-links">
                    <a href="/login">Вход</a> | <a href="/register">Регистрация</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
    <div class="main">
        @Body
    </div>
</div>

<style>
    .page { display: flex; height: 100vh; }
    .sidebar { width: 250px; background: #2c3e50; color: white; padding: 20px; }
    .brand { font-size: 24px; font-weight: bold; color: white; text-decoration: none; display: block; margin-bottom: 20px; }
    .user-info, .auth-links { margin-bottom: 20px; font-size: 14px; }
    .btn-logout { background: none; border: 1px solid white; color: white; border-radius: 4px; padding: 4px 8px; cursor: pointer; margin-left: 10px; }
    .main { flex: 1; padding: 20px; overflow: auto; }
</style>

@code {
    private async Task Logout()
    {
        await SignInManager.SignOutAsync();
        await JS.InvokeVoidAsync("forceRedirect", "/login");
    }
}