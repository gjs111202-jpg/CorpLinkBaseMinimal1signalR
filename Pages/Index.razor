@code {
    [Parameter] public string? ChatId { get; set; }
    private List<User> users = new();
    private List<Chat> chats = new();
    private List<User> favorites = new();
    private Chat? selectedChat;
    private string searchQuery = string.Empty;
    private string newMessageText = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private HubConnection? hubConnection;
    private int? joinedChatId;
    private string currentUserId = string.Empty;
    private int? editingMessageId;
    private string editMessageText = string.Empty;
    private ElementReference messagesContainer;
    private ElementReference messageInput;
    private bool needScroll = false;
    private int? activeMessageMenu = null;
    private CancellationTokenSource? toastCts;
    private string selectedChatTitle => selectedChat?.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User?.DisplayName ??
                                        selectedChat?.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User?.UserName ??
                                        selectedChat?.Title ?? "Чат";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        if (!string.IsNullOrEmpty(currentUserId))
        {
            await LoadUsersAndChatsAsync();
            await InitializeSignalRAsync();

            if (!string.IsNullOrEmpty(ChatId) && int.TryParse(ChatId, out int chatId))
            {
                var chat = chats.FirstOrDefault(c => c.Id == chatId);
                if (chat != null)
                    await SelectChat(chatId);
                else
                {
                    await LoadUsersAndChatsAsync();
                    if (chats.Any(c => c.Id == chatId))
                        await SelectChat(chatId);
                }
            }
        }
    }
    private async Task ShowToast(string message, bool isError)
    {
        if (isError)
        {
            errorMessage = message;
            successMessage = "";
        }
        else
        {
            successMessage = message;
            errorMessage = "";
        }
    
        await InvokeAsync(StateHasChanged);
    
        
        toastCts?.Cancel();
        toastCts = new CancellationTokenSource();
    
        try
        {
            await Task.Delay(3000, toastCts.Token);
            errorMessage = "";
            successMessage = "";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
           
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.LoadThemeAsync();
            ThemeService.OnThemeChanged += OnThemeChanged;
            await JS.InvokeVoidAsync("initClickOutside", DotNetObjectReference.Create(this));
        }
        
        if (needScroll && messagesContainer.Id != null)
        {
            needScroll = false;
            await Task.Delay(50);
            await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
        }
    }

    private async void OnThemeChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleThemeAsync();
    }

    [JSInvokable]
    public void CloseMenu()
    {
        activeMessageMenu = null;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMessageMenu(int messageId)
    {
        if (activeMessageMenu == messageId)
            activeMessageMenu = null;
        else
            activeMessageMenu = messageId;
    }

    private async Task InitializeSignalRAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int>("ReceiveMessage", async chatId =>
        {
            await RefreshAfterSignalRAsync(chatId);
            needScroll = true;
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<int>("ChatListChanged", async chatId =>
        {
            await RefreshAfterSignalRAsync(chatId);
        });

        await hubConnection.StartAsync();
    }

    private async Task HandleMessageKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(newMessageText) && editingMessageId == null)
        {
            await SendMessage();
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            await CreateChatBySearch();
        }
    }

    private async Task LoadUsersAndChatsAsync()
    {
        users = await MessengerService.GetUsersAsync();
        if (!string.IsNullOrEmpty(currentUserId))
        {
            chats = await MessengerService.GetChatsForUserAsync(currentUserId);
            favorites = await MessengerService.GetFavoritesAsync(currentUserId);
            if (selectedChat is not null)
                selectedChat = chats.FirstOrDefault(x => x.Id == selectedChat.Id);
        }
        else
        {
            chats = new List<Chat>();
            selectedChat = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateChatBySearch()
    {
        ClearMessages();
        if (string.IsNullOrEmpty(currentUserId) || string.IsNullOrWhiteSpace(searchQuery))
        {
            await ShowToast("Введите логин или email", true);
            return;
        }

        var result = await MessengerService.CreateDirectChatBySearchAsync(currentUserId, searchQuery.Trim());
        if (!result.Success)
        {
            await ShowToast(result.Error ?? "Ошибка создания чата", true);
            return;
        }

        searchQuery = string.Empty;
        await ShowToast("Чат создан", false);
        await LoadUsersAndChatsAsync();

        if (result.Chat is not null)
            await SelectChat(result.Chat.Id);
    }

    private async Task SelectChat(int chatId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        if (hubConnection is not null && joinedChatId.HasValue)
            await hubConnection.SendAsync("LeaveChat", $"chat-{joinedChatId.Value}");

        selectedChat = await MessengerService.GetChatForUserAsync(currentUserId, chatId);
        joinedChatId = selectedChat?.Id;
        CancelEdit();
        activeMessageMenu = null;

        if (hubConnection is not null && joinedChatId.HasValue)
            await hubConnection.SendAsync("JoinChat", $"chat-{joinedChatId.Value}");

        await InvokeAsync(StateHasChanged);
        needScroll = true;
        await InvokeAsync(StateHasChanged);
    }

    private void GoToMyProfile()
    {
        Navigation.NavigateTo("/profile");
    }

    private void GoToChatPartnerProfile()
    {
        var otherUser = selectedChat?.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User;
        if (otherUser != null)
            Navigation.NavigateTo($"/profile/{otherUser.Id}");
    }

    private void StartEdit(Message message)
    {
        editingMessageId = message.Id;
        editMessageText = message.Text;
        activeMessageMenu = null;
    }

    private void CancelEdit()
    {
        editingMessageId = null;
        editMessageText = string.Empty;
    }

    private void OpenProfile(string userId)
    {
        Navigation.NavigateTo($"/profile/{userId}");
    }

    private string GetAvatarLetter(User user)
    {
        var name = user.DisplayName ?? user.UserName;
        return string.IsNullOrEmpty(name) ? "?" : name[..1].ToUpper();
    }

    private async Task SaveEditAsync()
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId) || !editingMessageId.HasValue)
            return;

        var result = await MessengerService.UpdateMessageAsync(selectedChat.Id, editingMessageId.Value, currentUserId, editMessageText);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        CancelEdit();
        await RefreshAfterSignalRAsync(selectedChat.Id);
        needScroll = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteMessageAsync(Message message)
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId))
            return;

       
        if (!await JS.InvokeAsync<bool>("confirm", "Удалить это сообщение без возможности восстановления?"))
            return;

        var result = await MessengerService.DeleteMessageAsync(selectedChat.Id, message.Id, currentUserId);
        if (!result.Success)
        {
            await ShowToast(result.Error ?? "Ошибка удаления", true);
            return;
        }

        if (editingMessageId == message.Id)
            CancelEdit();

        activeMessageMenu = null;
        await RefreshAfterSignalRAsync(selectedChat.Id);
        await ShowToast("Сообщение удалено", false);
    }

    private async Task SendMessage()
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId) || string.IsNullOrWhiteSpace(newMessageText))
            return;

        var result = await MessengerService.SendMessageAsync(selectedChat.Id, currentUserId, newMessageText);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        newMessageText = string.Empty;
        await RefreshAfterSignalRAsync(selectedChat.Id);
        needScroll = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAfterSignalRAsync(int chatId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        chats = await MessengerService.GetChatsForUserAsync(currentUserId);
        favorites = await MessengerService.GetFavoritesAsync(currentUserId);
        if (selectedChat is not null && selectedChat.Id == chatId)
            selectedChat = await MessengerService.GetChatForUserAsync(currentUserId, chatId);

        await InvokeAsync(StateHasChanged);
    }

    private void ClearMessages()
    {
    }

    private async Task ToggleFavorite(string userId, bool isCurrentlyFavorite)
    {
        if (string.IsNullOrEmpty(userId)) return;
        
        try
        {
            if (isCurrentlyFavorite)
            {
                await MessengerService.RemoveFavoriteAsync(currentUserId, userId);
                successMessage = "Удалён из избранного";
            }
            else
            {
                await MessengerService.AddFavoriteAsync(currentUserId, userId);
                successMessage = "Добавлен в избранное";
            }
            
            await LoadUsersAndChatsAsync();
            await InvokeAsync(StateHasChanged);
            
            await Task.Delay(3000);
            successMessage = "";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
            errorMessage = "Ошибка при добавлении в избранное";
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            if (joinedChatId.HasValue)
            {
                try { await hubConnection.SendAsync("LeaveChat", $"chat-{joinedChatId.Value}"); }
                catch { }
            }
            await hubConnection.DisposeAsync();
        }
        
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }

    private async Task DeleteCurrentChat()
    {
        if (selectedChat == null) return;
        if (!await JS.InvokeAsync<bool>("confirm", "Удалить чат без возможности восстановления?")) return;

        var result = await MessengerService.DeleteChatAsync(selectedChat.Id, currentUserId);
        if (!result.Success)
        {
            await ShowToast(result.Error ?? "Ошибка удаления чата", true);
            return;
        }

        selectedChat = null;
        await LoadUsersAndChatsAsync();
        await ShowToast("Чат удалён", false);
    }


    private async Task RemoveFromFavorites(string favoriteUserId)
    {
        await MessengerService.RemoveFavoriteAsync(currentUserId, favoriteUserId);
        await LoadUsersAndChatsAsync();
        await ShowToast("Удалён из избранного", false);
    }
}