@page "/"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using CorpLinkBaseMinimal.Data
@using CorpLinkBaseMinimal.Services
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Web

@attribute [Authorize]
@implements IAsyncDisposable
@inject MessengerService MessengerService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>CorpLink — Чат</PageTitle>

<div class="chat-layout">
    <aside class="sidebar">
        <div class="brand">💬 CorpLink</div>
        
        <div class="block">
            <div class="block-title">👤 Мой профиль</div>
            <div class="current-user">
                <div class="user-avatar">
                    @{
                        var displayName = users.FirstOrDefault(u => u.Id == currentUserId)?.DisplayName ?? currentUserId;
                        var initials = displayName.Length >= 2 ? displayName[..2].ToUpper() : displayName[..1].ToUpper();
                    }
                    @initials
                </div>
                <div class="user-info">
                    <div class="user-name">@displayName</div>
                    <div class="user-status online">🟢 Онлайн</div>
                </div>
            </div>
            <a class="btn btn-logout" href="/logout">🚪 Выйти</a>
        </div>

        <div class="block">
            <div class="block-title">➕ Новый диалог</div>
            <input type="text"
                   class="input"
                   @bind="searchQuery"
                   @bind:event="oninput"
                   placeholder="Логин или email собеседника"
                   @onkeydown="HandleSearchKeyDown" />
            <button class="btn full" @onclick="CreateChatBySearch" disabled="@string.IsNullOrWhiteSpace(searchQuery)">
                🔍 Найти и создать чат
            </button>
        </div>

        <div class="block">
            <div class="block-title">💬 Мои чаты</div>
            <div class="chats-container">
                @if (!chats.Any())
                {
                    <div class="empty">📭 У вас пока нет чатов</div>
                }
                else
                {
                    @foreach (var chat in chats.OrderByDescending(c => c.Messages.LastOrDefault()?.CreatedAt))
                    {
                        var active = selectedChat?.Id == chat.Id;
                        var lastMessage = chat.Messages.LastOrDefault();
                        var otherUser = chat.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User;
                        var chatTitle = otherUser?.DisplayName ?? otherUser?.UserName ?? chat.Title;
                        
                        <div class="chat-item @(active ? "active" : "")" @onclick="() => SelectChat(chat.Id)">
                            <div class="chat-avatar">
                                @(chatTitle.Length >= 2 ? chatTitle[..2].ToUpper() : chatTitle[..1].ToUpper())
                            </div>
                            <div class="chat-content">
                                <div class="chat-title">@chatTitle</div>
                                <div class="chat-preview">
                                    @if (lastMessage is null)
                                    {
                                        <span>📝 Нет сообщений</span>
                                    }
                                    else
                                    {
                                        <span>@(lastMessage.SenderId == currentUserId ? "✏️ Вы: " : "")@(lastMessage.Text.Length > 30 ? lastMessage.Text[..30] + "..." : lastMessage.Text)</span>
                                    }
                                </div>
                            </div>
                            @if (lastMessage != null)
                            {
                                <div class="chat-time">@lastMessage.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </aside>

    <main class="chat-panel">
        @if (selectedChat is null)
        {
            <div class="placeholder">
                <div class="placeholder-icon">💬</div>
                <h3>Выберите чат</h3>
                <p>Начните диалог или создайте новый чат</p>
            </div>
        }
        else
        {
            <div class="chat-header">
                <div class="chat-header-info">
                    <div class="chat-header-avatar">
                        @(selectedChatTitle.Length >= 2 ? selectedChatTitle[..2].ToUpper() : selectedChatTitle[..1].ToUpper())
                    </div>
                    <div>
                        <div class="chat-name">@selectedChatTitle</div>
                        <div class="chat-subtitle">
                            👥 @string.Join(", ", selectedChat.Participants.Select(p => p.User?.DisplayName ?? p.User?.UserName))
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="messages" @ref="messagesContainer">
                @if (!selectedChat.Messages.Any())
                {
                    <div class="empty-messages">
                        <div class="empty-icon">💭</div>
                        <p>Напишите первое сообщение</p>
                    </div>
                }
                else
                {
                    @foreach (var message in selectedChat.Messages.OrderBy(m => m.CreatedAt))
                    {
                        var mine = message.SenderId == currentUserId;
                        <div class="message-wrap @(mine ? "mine" : "other")">
                            <div class="message-bubble">
                                <div class="message-author">@(message.Sender?.DisplayName ?? message.Sender?.UserName)</div>
                                
                                @if (mine && editingMessageId == message.Id)
                                {
                                    <textarea class="input edit-area" @bind="editMessageText" @bind:event="oninput" rows="3"></textarea>
                                    <div class="message-actions">
                                        <button class="btn btn-sm" @onclick="SaveEditAsync">💾 Сохранить</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">❌ Отмена</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="message-body">@message.Text</div>
                                    @if (message.EditedAt.HasValue)
                                    {
                                        <div class="message-edited">✏️ изменено</div>
                                    }
                                    @if (mine)
                                    {
                                        <div class="message-actions">
                                            <button class="icon-btn edit-btn" @onclick="() => StartEdit(message)" title="Изменить">
                                                ✏️ Изменить
                                            </button>
                                            <button class="icon-btn delete-btn" @onclick="() => DeleteMessageAsync(message)" title="Удалить">
                                                🗑️ Удалить
                                            </button>
                                        </div>
                                    }
                                }
                                <div class="message-time">@message.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                }
                <div class="scroll-anchor"></div>
            </div>
            
            <div class="composer">
                <div class="composer-wrapper">
                    <input class="input"
                           @bind="newMessageText"
                           @bind:event="oninput"
                           @onkeydown="HandleMessageKeyDown"
                           placeholder="✏️ Введите сообщение..."
                           @ref="messageInput" />
                    <button class="btn send-btn" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(newMessageText)">
                        📤 Отправить
                    </button>
                </div>
            </div>
        }
    </main>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="toast error">
        <span>❌</span> @errorMessage
    </div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="toast success">
        <span>✅</span> @successMessage
    </div>
}

<script>
    window.scrollToBottom = (element) => {
        if (element) {
            element.scrollTop = element.scrollHeight;
        }
    };
</script>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .chat-layout {
        display: grid;
        grid-template-columns: 360px 1fr;
        min-height: 100vh;
        background: #f0f2f5;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .sidebar {
        background: white;
        border-right: 1px solid #e4e6eb;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }

    .brand {
        font-size: 24px;
        font-weight: 800;
        padding: 20px;
        color: #2f5fe3;
        border-bottom: 1px solid #e4e6eb;
    }

    .block {
        margin: 16px;
        padding: 16px;
        background: #f8f9fa;
        border-radius: 16px;
    }

    .block-title {
        font-weight: 600;
        margin-bottom: 12px;
        color: #1e293b;
        font-size: 14px;
    }

    .current-user {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        padding: 8px;
        background: white;
        border-radius: 12px;
    }

    .user-avatar {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #2f5fe3, #1e40af);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 18px;
    }

    .user-info {
        flex: 1;
    }

    .user-name {
        font-weight: 600;
        color: #1e293b;
    }

    .user-status.online {
        font-size: 12px;
        color: #22c55e;
    }

    .input {
        width: 100%;
        padding: 10px 14px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        background: white;
        font-size: 14px;
        transition: all 0.2s;
    }

    .input:focus {
        outline: none;
        border-color: #2f5fe3;
        box-shadow: 0 0 0 3px rgba(47, 95, 227, 0.1);
    }

    .btn {
        padding: 10px 16px;
        border: none;
        border-radius: 12px;
        background: #2f5fe3;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 14px;
    }

    .btn:hover {
        background: #1e40af;
        transform: translateY(-1px);
    }

    .btn.full {
        width: 100%;
        margin-top: 8px;
    }

    .btn.btn-logout {
        background: #ef4444;
        width: 100%;
        text-align: center;
        display: block;
        text-decoration: none;
    }

    .btn.btn-logout:hover {
        background: #dc2626;
    }

    .btn.btn-sm {
        padding: 6px 12px;
        font-size: 12px;
    }

    .btn.btn-secondary {
        background: #6b7280;
    }

    .chats-container {
        max-height: 400px;
        overflow-y: auto;
    }

    .chat-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 6px;
    }

    .chat-item:hover {
        background: #eef2ff;
    }

    .chat-item.active {
        background: #eef2ff;
        border-left: 3px solid #2f5fe3;
    }

    .chat-avatar {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #c7d2fe, #a5b4fc);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #2f5fe3;
        font-size: 16px;
        flex-shrink: 0;
    }

    .chat-content {
        flex: 1;
        min-width: 0;
    }

    .chat-title {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .chat-preview {
        font-size: 13px;
        color: #64748b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-time {
        font-size: 11px;
        color: #94a3b8;
        flex-shrink: 0;
    }

    .chat-panel {
        display: flex;
        flex-direction: column;
        background: white;
    }

    .placeholder {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        color: #94a3b8;
    }

    .placeholder-icon {
        font-size: 64px;
    }

    .placeholder h3 {
        color: #64748b;
        font-weight: 500;
    }

    .chat-header {
        padding: 16px 24px;
        border-bottom: 1px solid #e4e6eb;
        background: white;
    }

    .chat-header-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .chat-header-avatar {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #c7d2fe, #a5b4fc);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #2f5fe3;
        font-size: 18px;
    }

    .chat-name {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
    }

    .chat-subtitle {
        font-size: 12px;
        color: #64748b;
        margin-top: 2px;
    }

    .messages {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #f8fafc;
    }

    .message-wrap {
        display: flex;
        animation: fadeIn 0.2s ease;
    }

    .message-wrap.mine {
        justify-content: flex-end;
    }

    .message-wrap.other {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 18px;
        background: white;
        border: 1px solid #e4e8f0;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .mine .message-bubble {
        background: #2f5fe3;
        border-color: #2f5fe3;
        color: white;
    }

    .message-author {
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .mine .message-author {
        color: #bfdbfe;
    }

    .other .message-author {
        color: #2f5fe3;
    }

    .message-body {
        font-size: 14px;
        word-wrap: break-word;
        white-space: pre-wrap;
    }

    .message-edited {
        margin-top: 4px;
        font-size: 10px;
        opacity: 0.7;
        font-style: italic;
    }

    .message-actions {
        margin-top: 8px;
        display: flex;
        gap: 12px;
    }

    .icon-btn {
        background: none;
        border: none;
        font-size: 12px;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        transition: all 0.2s;
        font-weight: 500;
    }

    .edit-btn {
        color: #2f5fe3;
    }

    .edit-btn:hover {
        background: #eef2ff;
    }

    .delete-btn {
        color: #ef4444;
    }

    .delete-btn:hover {
        background: #fef2f2;
    }

    .edit-area {
        margin-top: 6px;
        resize: vertical;
        min-height: 64px;
        font-family: inherit;
    }

    .message-time {
        font-size: 10px;
        margin-top: 4px;
        text-align: right;
        opacity: 0.7;
    }

    .empty-messages {
        text-align: center;
        padding: 60px;
        color: #94a3b8;
    }

    .empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .composer {
        padding: 16px 20px;
        background: white;
        border-top: 1px solid #e4e6eb;
    }

    .composer-wrapper {
        display: flex;
        gap: 12px;
    }

    .composer .input {
        flex: 1;
    }

    .send-btn {
        padding: 10px 24px;
        white-space: nowrap;
    }

    .send-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        padding: 12px 20px;
        border-radius: 12px;
        color: white;
        font-weight: 500;
        z-index: 1000;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: slideIn 0.3s ease;
    }

    .toast.error {
        background: #ef4444;
    }

    .toast.success {
        background: #22c55e;
    }

    .empty {
        text-align: center;
        color: #94a3b8;
        padding: 20px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(100px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 3px;
    }

    @@media (max-width: 768px) {
        .chat-layout {
            grid-template-columns: 1fr;
        }
        
        .message-bubble {
            max-width: 85%;
        }
        
        .chat-header {
            padding: 12px 16px;
        }
        
        .messages {
            padding: 12px;
        }
        
        .composer {
            padding: 12px;
        }
    }
</style>

@code {
    private List<User> users = new();
    private List<Chat> chats = new();
    private Chat? selectedChat;
    private string searchQuery = string.Empty;
    private string newMessageText = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private HubConnection? hubConnection;
    private int? joinedChatId;
    private string currentUserId = string.Empty;
    private int? editingMessageId;
    private string editMessageText = string.Empty;
    private ElementReference messagesContainer;
    private ElementReference messageInput;

    private string selectedChatTitle => selectedChat?.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User?.DisplayName ?? 
                                        selectedChat?.Participants.FirstOrDefault(p => p.UserId != currentUserId)?.User?.UserName ?? 
                                        selectedChat?.Title ?? "Чат";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        if (!string.IsNullOrEmpty(currentUserId))
        {
            await LoadUsersAndChatsAsync();
            await InitializeSignalRAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (selectedChat != null && messagesContainer.Id != null)
        {
            await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
        }
    }

    private async Task InitializeSignalRAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<int>("ReceiveMessage", async chatId =>
        {
            await RefreshAfterSignalRAsync(chatId);
            await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
        });

        hubConnection.On<int>("ChatListChanged", async chatId =>
        {
            await RefreshAfterSignalRAsync(chatId);
        });

        await hubConnection.StartAsync();
    }

    private async Task HandleMessageKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(newMessageText) && editingMessageId == null)
        {
            await SendMessage();
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            await CreateChatBySearch();
        }
    }

    private async Task LoadUsersAndChatsAsync()
    {
        users = await MessengerService.GetUsersAsync();
        if (!string.IsNullOrEmpty(currentUserId))
        {
            chats = await MessengerService.GetChatsForUserAsync(currentUserId);
            if (selectedChat is not null)
                selectedChat = chats.FirstOrDefault(x => x.Id == selectedChat.Id);
        }
        else
        {
            chats = new List<Chat>();
            selectedChat = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateChatBySearch()
    {
        ClearMessages();
        if (string.IsNullOrEmpty(currentUserId) || string.IsNullOrWhiteSpace(searchQuery))
        {
            errorMessage = "Введите логин или email";
            return;
        }

        var result = await MessengerService.CreateDirectChatBySearchAsync(currentUserId, searchQuery);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        searchQuery = string.Empty;
        successMessage = "Чат создан";
        await LoadUsersAndChatsAsync();

        if (result.Chat is not null)
            await SelectChat(result.Chat.Id);
    }

    private async Task SelectChat(int chatId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        if (hubConnection is not null && joinedChatId.HasValue)
            await hubConnection.SendAsync("LeaveChat", $"chat-{joinedChatId.Value}");

        selectedChat = await MessengerService.GetChatForUserAsync(currentUserId, chatId);
        joinedChatId = selectedChat?.Id;
        CancelEdit();

        if (hubConnection is not null && joinedChatId.HasValue)
            await hubConnection.SendAsync("JoinChat", $"chat-{joinedChatId.Value}");

        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
    }

    private void StartEdit(Message message)
    {
        editingMessageId = message.Id;
        editMessageText = message.Text;
    }

    private void CancelEdit()
    {
        editingMessageId = null;
        editMessageText = string.Empty;
    }

    private async Task SaveEditAsync()
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId) || !editingMessageId.HasValue)
            return;

        var result = await MessengerService.UpdateMessageAsync(selectedChat.Id, editingMessageId.Value, currentUserId, editMessageText);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        CancelEdit();
        await RefreshAfterSignalRAsync(selectedChat.Id);
    }

    private async Task DeleteMessageAsync(Message message)
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId))
            return;

        var result = await MessengerService.DeleteMessageAsync(selectedChat.Id, message.Id, currentUserId);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        if (editingMessageId == message.Id)
            CancelEdit();

        await RefreshAfterSignalRAsync(selectedChat.Id);
        successMessage = "Сообщение удалено";
    }

    private async Task SendMessage()
    {
        ClearMessages();
        if (selectedChat is null || string.IsNullOrEmpty(currentUserId) || string.IsNullOrWhiteSpace(newMessageText))
            return;

        var result = await MessengerService.SendMessageAsync(selectedChat.Id, currentUserId, newMessageText);
        if (!result.Success)
        {
            errorMessage = result.Error;
            return;
        }

        newMessageText = string.Empty;
        await RefreshAfterSignalRAsync(selectedChat.Id);
        await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
    }

    private async Task RefreshAfterSignalRAsync(int chatId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        chats = await MessengerService.GetChatsForUserAsync(currentUserId);
        if (selectedChat is not null && selectedChat.Id == chatId)
            selectedChat = await MessengerService.GetChatForUserAsync(currentUserId, chatId);

        await InvokeAsync(StateHasChanged);
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            if (joinedChatId.HasValue)
            {
                try { await hubConnection.SendAsync("LeaveChat", $"chat-{joinedChatId.Value}"); }
                catch { }
            }
            await hubConnection.DisposeAsync();
        }
    }
}